generator client {
  provider      = "prisma-client-js"
  output        = "../backend/node_modules/.prisma/client"
  binaryTargets = ["native"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique // "MEX", "RSA"
  flagEmoji   String
  groupStage  String   // "A", "B", etc.
  anthem      AudioStream?
  homePlayers Player[]
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
  createdAt   DateTime @default(now())
}

model Player {
  id       String @id @default(cuid())
  name     String
  number   Int
  position String // GK, DEF, MID, FWD
  teamId   String
  team     Team   @relation(fields: [teamId], references: [id])
}

model Match {
  id           String        @id @default(cuid())
  fixture      Int           @unique // API-Football fixture id
  homeTeamId   String
  awayTeamId   String
  homeTeam     Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venue        String
  city         String
  date         DateTime
  status       String        @default("NS") // NS | LIVE | HT | FT | AET | PEN
  homeScore    Int           @default(0)
  awayScore    Int           @default(0)
  elapsed      Int           @default(0) // minutes played
  metrics      LiveMetric[]
  markets      KalshiMarket[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model LiveMetric {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id])
  teamCode    String
  metricType  String   // "possession", "shots_on", "shots_off", "corners", "fouls", "yellow_cards", "red_cards"
  value       Float
  recordedAt  DateTime @default(now())
}

model KalshiMarket {
  id           String   @id @default(cuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id])
  contractSlug String
  outcome      String   // "home_win", "away_win", "draw"
  price        Float    // 0.01 – 0.99 implied probability
  volume       Int      @default(0)
  lastTick     DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([matchId, outcome])
}

model AudioStream {
  id            String   @id @default(cuid())
  teamId        String   @unique
  team          Team     @relation(fields: [teamId], references: [id])
  title         String
  artistCredit  String   @default("Suno AI")
  audioUrl      String   // public URL or /api/audio/:id
  coverArt      String?
  durationSecs  Int
  playCount     Int      @default(0)
  listenSeconds Int      @default(0) // cumulative seconds played across all sessions
  tiktokDeepLink String? // tiktok://music/:id or https://tiktok.com/music/:id
  createdAt     DateTime @default(now())
}

