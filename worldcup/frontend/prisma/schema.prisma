generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  WHITE_LABEL  // Paid partner — gets branded embed + API access
  USER
}

enum SponsorTier {
  TITLE        // "Presented by X" — top placement everywhere
  MATCH        // Sponsors individual match pages
  GROUP        // Sponsors a group stage
  ANTHEM       // Sponsors the anthems page / specific team anthem
  BANNER       // Standard banner slot
}

enum AdSlotPlacement {
  HOME_HERO    // Top of dashboard
  SCHEDULE_TOP // Above schedule list
  MATCH_DETAIL // Match detail page header
  STANDINGS    // Below standings table
  ANTHEMS      // Anthems page
  SIDEBAR      // Right sidebar (desktop)
}

model User {
  id               String              @id @default(cuid())
  name             String?
  email            String              @unique
  emailVerified    DateTime?
  image            String?
  role             Role                @default(USER)
  accounts         Account[]
  sessions         Session[]
  predictions      Prediction[]
  whiteLabelConfig WhiteLabelPartner?
  createdAt        DateTime            @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fixtureId Int
  home      Int
  away      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, fixtureId])
}

model Team {
  id          String        @id @default(cuid())
  name        String        @unique
  code        String        @unique
  flagEmoji   String
  groupStage  String
  anthem      AudioStream?
  homePlayers Player[]
  homeMatches Match[]       @relation("HomeTeam")
  awayMatches Match[]       @relation("AwayTeam")
  createdAt   DateTime      @default(now())
}

model Player {
  id             String                @id @default(cuid())
  name           String
  number         Int
  position       String
  teamId         String
  team           Team                  @relation(fields: [teamId], references: [id])
  club           String                @default("")
  league         String                @default("")
  caps           Int                   @default(0)
  goals          Int                   @default(0)
  dateOfBirth    String                @default("")
  photoUrl       String?
  tournamentStat PlayerTournamentStat?
  matchStats     PlayerMatchStat[]
}

model PlayerTournamentStat {
  id               String   @id @default(cuid())
  playerId         String   @unique
  player           Player   @relation(fields: [playerId], references: [id])
  // Totals (accumulated across all matches)
  goals            Int      @default(0)
  assists          Int      @default(0)
  matches          Int      @default(0)
  minutesPlayed    Int      @default(0)
  yellowCards      Int      @default(0)
  redCards         Int      @default(0)
  rating           Float    @default(0)   // average across matches
  // Shooting
  shotsTotal       Int      @default(0)
  shotsOnTarget    Int      @default(0)
  // Passing
  passesTotal      Int      @default(0)
  passesKey        Int      @default(0)
  // Defensive
  tacklesTotal     Int      @default(0)
  tackleBlocks     Int      @default(0)
  interceptions    Int      @default(0)
  // Duels
  duelsTotal       Int      @default(0)
  duelsWon         Int      @default(0)
  // Dribbles
  dribblesAttempts Int      @default(0)
  dribblesSuccess  Int      @default(0)
  // Discipline
  foulsDrawn       Int      @default(0)
  foulsCommitted   Int      @default(0)
  // Penalties
  penaltiesScored  Int      @default(0)
  penaltiesMissed  Int      @default(0)
  updatedAt        DateTime @updatedAt
}

model PlayerMatchStat {
  id               String   @id @default(cuid())
  playerId         String
  player           Player   @relation(fields: [playerId], references: [id])
  matchId          String
  match            Match    @relation(fields: [matchId], references: [id])
  minutesPlayed    Int      @default(0)
  rating           Float    @default(0)
  goals            Int      @default(0)
  assists          Int      @default(0)
  captain          Boolean  @default(false)
  substitute       Boolean  @default(false)
  shotsTotal       Int      @default(0)
  shotsOnTarget    Int      @default(0)
  passesTotal      Int      @default(0)
  passesKey        Int      @default(0)
  passAccuracy     Int      @default(0)
  tacklesTotal     Int      @default(0)
  tackleBlocks     Int      @default(0)
  interceptions    Int      @default(0)
  duelsTotal       Int      @default(0)
  duelsWon         Int      @default(0)
  dribblesAttempts Int      @default(0)
  dribblesSuccess  Int      @default(0)
  foulsDrawn       Int      @default(0)
  foulsCommitted   Int      @default(0)
  yellowCards      Int      @default(0)
  redCards         Int      @default(0)
  penaltiesScored  Int      @default(0)
  penaltiesMissed  Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([playerId, matchId])
}

model Match {
  id           String            @id @default(cuid())
  fixture      Int               @unique
  homeTeamId   String
  awayTeamId   String
  homeTeam     Team              @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team              @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venue        String
  city         String
  date         DateTime
  status       String            @default("NS")
  homeScore    Int               @default(0)
  awayScore    Int               @default(0)
  elapsed      Int               @default(0)
  round        String            @default("Group Stage")
  referee      String?           // match official (from api-football) — powers Officials profiles
  goalEvents   Json?             // admin override: [{minute,team,scorer,assist,isOwnGoal,isPenalty}]
  metrics      LiveMetric[]
  markets      KalshiMarket[]
  playerStats  PlayerMatchStat[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model NewsStory {
  id            String   @id @default(cuid())
  date          DateTime           // the day the story pertains to (UTC)
  matchday      Int?               // optional matchday number
  fixture       Int?               // api-football fixture id (set for GAME RECAP, for dedup)
  category      String             // GAME RECAP | DAILY RECAP | MATCH REPORT | ANALYSIS | STANDINGS | METRIC SPOTLIGHT
  headline      String
  body          String
  teamsInvolved String[]           // team codes (TLAs) for flag display
  audioUrl      String?
  generatedAt   DateTime @default(now())

  @@index([date])
  @@index([fixture])
}

// One canonical Roundtable episode per fixture (owner 7/18): persisting the
// script means every serverless instance serves the SAME episode (so the
// global TTS audio cache works for all users) and episodes survive redeploys
// as part of the tournament archive.
model RoundtableEpisode {
  id          String   @id @default(cuid())
  fixture     Int      @unique // api-football fixture id
  title       String
  matchup     String
  lines       Json               // [{ speaker, text }]
  generatedAt DateTime @default(now())
}

model LiveMetric {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id])
  teamCode   String
  metricType String
  value      Float
  recordedAt DateTime @default(now())
}

model KalshiMarket {
  id           String   @id @default(cuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id])
  contractSlug String
  outcome      String
  price        Float
  volume       Int      @default(0)
  lastTick     DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([matchId, outcome])
}

model AudioStream {
  id             String   @id @default(cuid())
  teamId         String?  @unique
  team           Team?    @relation(fields: [teamId], references: [id])
  title          String
  artistCredit   String   @default("Suno AI × Studio0x")
  audioUrl       String
  coverArt       String?
  durationSecs   Int      @default(180)
  playCount      Int      @default(0)
  listenSeconds  Int      @default(0)
  shareClicks    Int      @default(0)
  tiktokDeepLink String?
  createdAt      DateTime @default(now())
}

// ── Sponsors & Advertising ─────────────────────────────────────────────────

model Sponsor {
  id          String      @id @default(cuid())
  name        String      @unique
  logoUrl     String?
  websiteUrl  String?
  tier        SponsorTier
  active      Boolean     @default(true)
  startDate   DateTime?
  endDate     DateTime?
  adSlots     AdSlot[]
  createdAt   DateTime    @default(now())
}

model AdSlot {
  id          String          @id @default(cuid())
  sponsorId   String
  sponsor     Sponsor         @relation(fields: [sponsorId], references: [id])
  placement   AdSlotPlacement
  imageUrl    String?         // banner creative
  linkUrl     String?
  ctaText     String?         // "Visit →"
  active      Boolean         @default(true)
  impressions Int             @default(0)
  clicks      Int             @default(0)
  // Optional targeting
  matchId     String?         // null = all matches
  groupCode   String?         // null = all groups
  createdAt   DateTime        @default(now())
}

// ── White Label Partners ───────────────────────────────────────────────────

model WhiteLabelPartner {
  id           String   @id @default(cuid())
  userId       String   @unique  // must have role = WHITE_LABEL
  user         User     @relation(fields: [userId], references: [id])
  orgName      String
  logoUrl      String?
  primaryColor String   @default("#F5B800")  // defaults to brand-gold
  domain       String?  // custom domain if they have one
  embedKey     String   @unique @default(cuid())  // API key for embed widget
  active       Boolean  @default(true)
  planName     String   @default("starter")  // starter, pro, enterprise
  createdAt    DateTime @default(now())
}

// ── Live event capture (VAR Freeze™ §15) ─────────────────────────────────────
// The api-football feed carries only MATCH MINUTES for events. To measure real
// wall-clock gaps (e.g. whistle→penalty after a long VAR review — owner heard
// 3m11s on the FRA-MAR broadcast), we record when each event FIRST APPEARS in
// our live polling. firstSeenAt deltas ≈ real elapsed time ± feed latency —
// always disclosed as a Studio0x live-capture measurement. Rows are only ever
// written while a match is LIVE/HT (writing after FT would fabricate timing).
model MatchEventLog {
  id          String   @id @default(cuid())
  fixture     Int
  eventKey    String   // `${type}|${detail}|${minute}|${player}` — stable dedup key
  minute      Int
  type        String
  detail      String
  team        String
  player      String?
  firstSeenAt DateTime @default(now())

  @@unique([fixture, eventKey])
  @@index([fixture])
}

// Heat vs. Outcomes (Cramp Watch™ aggregate, backlog §16): one row per fixture
// with the REAL kickoff-hour weather (Open-Meteo hourly archive — retrieval of
// archived fact, honest to backfill) plus outcome facts computed from the
// api-football events feed once the match is FT. climateControlled venues are
// excluded from heat buckets — their outdoor reading isn't match conditions.
model MatchWeather {
  id                String   @id @default(cuid())
  fixture           Int      @unique
  kickoff           DateTime
  tempC             Float
  feelsC            Float
  humidity          Float
  band              String   // Low | Moderate | High | Extreme (lib/heat.ts)
  source            String   // "archive" (past day) | "recent" (same-day hourly)
  climateControlled Boolean  @default(false)
  // Air quality at kickoff (Open-Meteo Air Quality/CAMS): US AQI + PM2.5 µg/m³.
  // Catches wildfire smoke. null = service had no data — never fabricated.
  aqi               Float?
  pm25              Float?
  // Outcome facts — null until the match is FT and events were ingested
  totalGoals        Int?
  lateGoals         Int?     // goals scored 75'+ (excl. missed pens)
  cards             Int?
  subsAfter75       Int?     // labeled PROXY for fatigue — no cramp event exists
  capturedAt        DateTime @default(now())

  @@index([band])
}
