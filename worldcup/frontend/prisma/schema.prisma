generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url = env("DATABASE_URL")
}

model Team {
  id          String        @id @default(cuid())
  name        String        @unique
  code        String        @unique
  flagEmoji   String
  groupStage  String
  anthem      AudioStream?
  homePlayers Player[]
  homeMatches Match[]       @relation("HomeTeam")
  awayMatches Match[]       @relation("AwayTeam")
  createdAt   DateTime      @default(now())
}

model Player {
  id       String @id @default(cuid())
  name     String
  number   Int
  position String
  teamId   String
  team     Team   @relation(fields: [teamId], references: [id])
}

model Match {
  id          String         @id @default(cuid())
  fixture     Int            @unique
  homeTeamId  String
  awayTeamId  String
  homeTeam    Team           @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team           @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venue       String
  city        String
  date        DateTime
  status      String         @default("NS")
  homeScore   Int            @default(0)
  awayScore   Int            @default(0)
  elapsed     Int            @default(0)
  metrics     LiveMetric[]
  markets     KalshiMarket[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model LiveMetric {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id])
  teamCode   String
  metricType String
  value      Float
  recordedAt DateTime @default(now())
}

model KalshiMarket {
  id           String   @id @default(cuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id])
  contractSlug String
  outcome      String
  price        Float
  volume       Int      @default(0)
  lastTick     DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([matchId, outcome])
}

model AudioStream {
  id             String   @id @default(cuid())
  teamId         String   @unique
  team           Team     @relation(fields: [teamId], references: [id])
  title          String
  artistCredit   String   @default("Suno AI")
  audioUrl       String
  coverArt       String?
  durationSecs   Int
  playCount      Int      @default(0)
  listenSeconds  Int      @default(0)
  tiktokDeepLink String?
  createdAt      DateTime @default(now())
}
