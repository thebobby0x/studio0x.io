{
  "buildCommand": "npx prisma generate --schema=prisma/schema.prisma && npx prisma db push --schema=prisma/schema.prisma && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- ..",
  "crons": [
    { "path": "/api/news/generate",    "schedule": "0 6 * * *" },
    { "path": "/api/cron/ingest-stats", "schedule": "30 2 * * *" }
  ]
}
