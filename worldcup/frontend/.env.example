# Neon PostgreSQL — get from Neon dashboard → Connection string
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.neon.tech/neondb?sslmode=require"

# ── Live data integrations (optional — falls back to simulation if unset) ──

# Kalshi prediction market API key
# Get from: https://kalshi.com/account/developer → API Keys
# Enables real Kalshi contract prices for match outcome markets
KALSHI_API_KEY=""

# Football-Data.org API key (free tier: 10 req/min)
# Get from: https://www.football-data.org/client/register
# Enables real live scores, match status, and elapsed time from FIFA WC 2026
FOOTBALL_DATA_API_KEY=""

# Admin seed secret (optional override — defaults to "wc2026studio0x")
SEED_SECRET=""
